<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= (typeof title !== 'undefined' && title) ? title : 'Form SaaS' %></title>

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
    integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN"
    crossorigin="anonymous"
  />

  <!-- Icons -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
    rel="stylesheet"
  />

  <!-- Typography -->
  <link
    href="https://cdn.jsdelivr.net/npm/@fontsource/public-sans@5.1.1/index.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/@fontsource/sora@5.1.1/index.min.css"
    rel="stylesheet"
  />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body class="app-bg">
  <nav class="navbar navbar-expand-lg navbar-dark glass-nav sticky-top">
    <div class="container">
      <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
        <span class="brand-dot"></span>
        Form SaaS
      </a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div id="nav" class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
          <% if (httpsEnabled) { %>
            <li class="nav-item">
              <span class="secure-chip"><i class="bi bi-shield-lock"></i> HTTPS</span>
            </li>
          <% } %>
          <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-grid-1x2"></i> Accueil</a></li>
          <% if (currentUser) { %>
            <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
            <li class="nav-item"><a class="nav-link" href="/settings"><i class="bi bi-gear"></i> Parametres</a></li>
            <li class="nav-item">
              <span class="company-chip"><i class="bi bi-building"></i> <%= currentUser.companyName %></span>
            </li>
            <li class="nav-item">
              <form method="POST" action="/logout" class="d-inline">
                <button class="btn btn-outline-light rounded-pill px-3" type="submit">
                  <i class="bi bi-box-arrow-right"></i> Deconnexion
                </button>
              </form>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/login"><i class="bi bi-box-arrow-in-right"></i> Connexion</a></li>
            <li class="nav-item">
              <a class="btn btn-primary rounded-pill px-3" href="/register">
                <i class="bi bi-person-plus"></i> Inscription
              </a>
            </li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <main class="container py-4 py-lg-5">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger border-0 shadow-sm d-flex align-items-center gap-2 rounded-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <div><%= error %></div>
      </div>
    <% } %>

    <%- body %>
  </main>

  <footer class="container pb-4">
    <div class="text-center text-white-50 small">
      © <%= new Date().getFullYear() %> Form SaaS • Powered by Node/Express
    </div>
  </footer>

  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
    crossorigin="anonymous"
  ></script>
</body>
</html>
