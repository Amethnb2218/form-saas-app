<section class="home-page">
  <div class="row g-4 align-items-stretch">
    <div class="col-xl-8">
      <div class="card-glass home-hero p-4 p-lg-5 h-100">
        <div class="home-chip d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill mb-3">
          <i class="bi bi-stars"></i>
          <span class="small">Plateforme SaaS • Formulaires intelligents</span>
        </div>

        <h1 class="home-title mb-3">
          Transforme tes formulaires en
          <span class="home-title-gradient">machine a conversion</span>.
        </h1>

        <p class="home-subtitle mb-4">
          Cree des parcours fluides, centralise les soumissions et partage des formulaires publics en quelques clics.
        </p>

        <div class="d-flex flex-wrap gap-2 mb-4">
          <a class="btn btn-primary btn-lg rounded-pill px-4" href="/register">
            <i class="bi bi-rocket-takeoff"></i> Demarrer gratuitement
          </a>
          <a class="btn btn-outline-light btn-lg rounded-pill px-4" href="/login">
            <i class="bi bi-box-arrow-in-right"></i> Acceder a mon espace
          </a>
        </div>

        <div class="row g-3 home-metrics">
          <div class="col-sm-4">
            <div class="metric-tile h-100">
              <div class="metric-value"><%= (forms && forms.length) ? forms.length : 0 %></div>
              <div class="metric-label">Formulaires publics</div>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="metric-tile h-100">
              <div class="metric-value"><%= (companies && companies.length) ? companies.length : 0 %></div>
              <div class="metric-label">Entreprises actives</div>
            </div>
          </div>
          <div class="col-sm-4">
            <div class="metric-tile h-100">
              <div class="metric-value">24/7</div>
              <div class="metric-label">Collecte continue</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-4">
      <div class="card-glass p-4 h-100 home-company-panel">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h5 class="fw-bold mb-0"><i class="bi bi-building"></i> Entreprises inscrites</h5>
          <span class="badge rounded-pill text-bg-light"><%= (companies && companies.length) ? companies.length : 0 %></span>
        </div>

        <% if (companies && companies.length) { %>
          <div class="company-stack d-grid gap-2">
            <% companies.slice(0, 6).forEach(c => { %>
              <div class="company-item d-flex align-items-center gap-3">
                <div class="company-avatar">
                  <%= (c.companyName || c.name || 'E').charAt(0).toUpperCase() %>
                </div>
                <div>
                  <div class="fw-semibold"><%= c.companyName || c.name || 'Entreprise' %></div>
                  <div class="small text-white-60">Espace entreprise actif</div>
                </div>
              </div>
            <% }) %>
          </div>

          <% if (companies.length > 6) { %>
            <div class="small text-white-60 mt-3">+ <%= companies.length - 6 %> autres entreprises</div>
          <% } %>
        <% } else { %>
          <div class="empty-state text-white-60">
            <i class="bi bi-inboxes me-2"></i>
            Aucune entreprise pour le moment.
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <section class="mt-4">
    <div class="card-glass p-4 public-forms-shell">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-ui-checks-grid"></i> Formulaires publics</h5>
        <span class="badge rounded-pill text-bg-light"><%= (forms && forms.length) ? forms.length : 0 %></span>
      </div>

      <% if (forms && forms.length) { %>
        <div class="row g-3">
          <% forms.forEach(form => { %>
            <div class="col-md-6 col-xl-4">
              <article class="public-form-card h-100">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <span class="public-form-badge"><i class="bi bi-broadcast"></i> Public</span>
                  <span class="small text-white-60"><%= new Date(form.createdAt || Date.now()).toLocaleDateString() %></span>
                </div>
                <h6 class="fw-bold mb-1"><%= form.title %></h6>
                <div class="small text-white-60 mb-3">
                  <i class="bi bi-building"></i>
                  <%= form.company?.companyName || 'Entreprise' %>
                </div>
                <div class="d-flex align-items-center gap-2 small text-white-60 mb-3">
                  <span><i class="bi bi-tag"></i> <%= form.category || 'General' %></span>
                  <span class="ms-auto"><i class="bi bi-bar-chart"></i> <%= form.submissionCount || 0 %> reponses</span>
                </div>
                <a class="btn btn-outline-light btn-sm rounded-pill" href="<%= form.slug ? ('/f/' + form.slug) : ('/form/' + form._id) %>">
                  <i class="bi bi-box-arrow-up-right"></i> Repondre
                </a>
              </article>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state text-white-60">
          <i class="bi bi-ui-checks-grid me-2"></i>
          Aucun formulaire public pour le moment.
        </div>
      <% } %>
    </div>
  </section>
</section>
