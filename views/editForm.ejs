<div class="row justify-content-center">
  <div class="col-xl-10">
    <div class="card-glass p-4 p-lg-5 text-white shadow-lg">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h2 class="fw-bold mb-1">Modifier le formulaire</h2>
          <div class="text-white-60"><%= form.title %></div>
        </div>
        <a href="/dashboard" class="btn btn-outline-light rounded-pill"><i class="bi bi-arrow-left"></i> Retour</a>
      </div>

      <form class="input-glow" method="POST" action="/form/edit/<%= form._id %>">
        <% const fieldRows = Array.isArray(formData.fields) && formData.fields.length
          ? formData.fields
          : [{ name: '', label: '', type: 'text', required: false, placeholder: '', helpText: '' }]; %>

        <div class="row g-3">
          <div class="col-md-8">
            <label class="form-label">Titre</label>
            <input class="form-control form-control-lg" name="title" value="<%= formData.title %>" required />
          </div>
          <div class="col-md-4">
            <label class="form-label">Slug public</label>
            <input class="form-control form-control-lg" name="slug" value="<%= formData.slug %>" />
          </div>
          <div class="col-md-4">
            <label class="form-label">Categorie</label>
            <select class="form-select form-select-lg" name="category">
              <% categories.forEach(category => { %>
                <option value="<%= category %>" <%= formData.category === category ? 'selected' : '' %>><%= category %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Statut</label>
            <select class="form-select form-select-lg" name="status">
              <option value="published" <%= formData.status === 'published' ? 'selected' : '' %>>Publie</option>
              <option value="draft" <%= formData.status === 'draft' ? 'selected' : '' %>>Brouillon</option>
              <option value="archived" <%= formData.status === 'archived' ? 'selected' : '' %>>Archive</option>
            </select>
          </div>
          <div class="col-md-4">
            <label class="form-label">Upload de fichier</label>
            <select class="form-select form-select-lg" name="allowFileUpload">
              <option value="false" <%= !formData.allowFileUpload ? 'selected' : '' %>>Non</option>
              <option value="true" <%= formData.allowFileUpload ? 'selected' : '' %>>Oui</option>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label">Description</label>
            <textarea class="form-control bg-glass" rows="3" name="description"><%= formData.description %></textarea>
          </div>
          <div class="col-12">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
              <label class="form-label mb-0">Champs du formulaire</label>
              <button type="button" id="addFieldRowBtn" class="btn btn-outline-light btn-sm rounded-pill">
                <i class="bi bi-plus-circle"></i> Ajouter un champ
              </button>
            </div>

            <div id="fieldRows" class="field-builder d-grid gap-2">
              <% fieldRows.forEach((field, index) => { %>
                <div class="field-row card-glass p-3" data-row-index="<%= index %>">
                  <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                      <label class="form-label">Nom technique (optionnel)</label>
                      <input class="form-control" name="fieldName[]" value="<%= field.name || '' %>" placeholder="full_name" />
                    </div>
                    <div class="col-md-3">
                      <label class="form-label">Label</label>
                      <input class="form-control" name="fieldLabel[]" value="<%= field.label || '' %>" placeholder="Nom complet" />
                    </div>
                    <div class="col-md-2">
                      <label class="form-label">Type</label>
                      <select class="form-select" name="fieldType[]">
                        <option value="text" <%= (field.type || 'text') === 'text' ? 'selected' : '' %>>Texte</option>
                        <option value="email" <%= field.type === 'email' ? 'selected' : '' %>>Email</option>
                        <option value="number" <%= field.type === 'number' ? 'selected' : '' %>>Nombre</option>
                        <option value="date" <%= field.type === 'date' ? 'selected' : '' %>>Date</option>
                        <option value="textarea" <%= field.type === 'textarea' ? 'selected' : '' %>>Zone de texte</option>
                        <option value="tel" <%= field.type === 'tel' ? 'selected' : '' %>>Telephone</option>
                        <option value="url" <%= field.type === 'url' ? 'selected' : '' %>>URL</option>
                        <option value="checkbox" <%= field.type === 'checkbox' ? 'selected' : '' %>>Case a cocher</option>
                      </select>
                    </div>
                    <div class="col-md-2">
                      <label class="form-label">Obligatoire</label>
                      <select class="form-select" name="fieldRequired[]">
                        <option value="false" <%= !field.required ? 'selected' : '' %>>Non</option>
                        <option value="true" <%= field.required ? 'selected' : '' %>>Oui</option>
                      </select>
                    </div>
                    <div class="col-md-2">
                      <button type="button" class="btn btn-outline-light w-100 js-remove-field">
                        <i class="bi bi-trash"></i> Supprimer
                      </button>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Placeholder</label>
                      <input class="form-control" name="fieldPlaceholder[]" value="<%= field.placeholder || '' %>" placeholder="Ex: Marie Diallo" />
                    </div>
                    <div class="col-md-6">
                      <label class="form-label">Texte d'aide</label>
                      <input class="form-control" name="fieldHelpText[]" value="<%= field.helpText || '' %>" placeholder="Information complementaire" />
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>

            <template id="fieldRowTemplate">
              <div class="field-row card-glass p-3">
                <div class="row g-2 align-items-end">
                  <div class="col-md-3">
                    <label class="form-label">Nom technique (optionnel)</label>
                    <input class="form-control" name="fieldName[]" placeholder="full_name" />
                  </div>
                  <div class="col-md-3">
                    <label class="form-label">Label</label>
                    <input class="form-control" name="fieldLabel[]" placeholder="Nom complet" />
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Type</label>
                    <select class="form-select" name="fieldType[]">
                      <option value="text">Texte</option>
                      <option value="email">Email</option>
                      <option value="number">Nombre</option>
                      <option value="date">Date</option>
                      <option value="textarea">Zone de texte</option>
                      <option value="tel">Telephone</option>
                      <option value="url">URL</option>
                      <option value="checkbox">Case a cocher</option>
                    </select>
                  </div>
                  <div class="col-md-2">
                    <label class="form-label">Obligatoire</label>
                    <select class="form-select" name="fieldRequired[]">
                      <option value="false" selected>Non</option>
                      <option value="true">Oui</option>
                    </select>
                  </div>
                  <div class="col-md-2">
                    <button type="button" class="btn btn-outline-light w-100 js-remove-field">
                      <i class="bi bi-trash"></i> Supprimer
                    </button>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Placeholder</label>
                    <input class="form-control" name="fieldPlaceholder[]" placeholder="Ex: Marie Diallo" />
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Texte d'aide</label>
                    <input class="form-control" name="fieldHelpText[]" placeholder="Information complementaire" />
                  </div>
                </div>
              </div>
            </template>

            <div class="form-text text-white-60 mt-2">Edition simple: modifie les champs sans toucher au JSON.</div>
          </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
          <button class="btn btn-primary btn-lg rounded-pill px-4">
            <i class="bi bi-save2"></i> Enregistrer
          </button>
          <a target="_blank" href="<%= formData.slug ? ('/f/' + formData.slug) : ('/form/' + form._id) %>" class="btn btn-outline-light btn-lg rounded-pill px-4">
            <i class="bi bi-box-arrow-up-right"></i> Voir le formulaire
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/field-builder.js"></script>
